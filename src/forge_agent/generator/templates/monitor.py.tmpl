"""监控告警类 Agent 模板 — 持续监控指标，异常时告警。"""

from __future__ import annotations

from typing import ClassVar

from forge_agent.core.base import BaseAgent
from forge_agent.core.context import AgentContext
from forge_agent.core.contracts import AgentReport
from forge_agent.core.enums import Action, Verdict


class MonitorAgent(BaseAgent):
    """监控告警 Agent — 持续监控指标并在异常时发出告警。"""

    agent_id: ClassVar[str] = "domain.monitor_name"
    name: ClassVar[str] = "Monitor Agent"
    domain: ClassVar[str] = "generic"
    version: ClassVar[str] = "0.1.0"

    # 告警阈值 (可在 payload 中覆盖)
    DEFAULT_THRESHOLD = 0.05  # 5%

    async def observe(self, ctx: AgentContext) -> dict:
        """获取当前监控指标和历史基线。

        典型实现：
        - 从 ctx.payload 获取监控目标（ticker / server_id 等）
        - 调用 API 或 self.searcher 获取当前状态
        - 从 self.memory 获取历史数据用于对比
        """
        target = ctx.payload.get("target", "")
        threshold = ctx.payload.get("threshold", self.DEFAULT_THRESHOLD)

        # 获取当前值
        current_value = ctx.payload.get("current_value", 0.0)

        # 获取历史基线 (如果有 memory)
        baseline = 0.0
        if self.memory:
            history = await self.memory.get(f"baseline:{target}")
            if history:
                baseline = float(history.get("value", 0.0))

        return {
            "target": target,
            "current_value": current_value,
            "baseline": baseline,
            "threshold": threshold,
        }

    async def decide(self, ctx: AgentContext, observation: dict) -> dict:
        """对比当前值与阈值，判断是否告警。"""
        current = observation.get("current_value", 0.0)
        baseline = observation.get("baseline", 0.0)
        threshold = observation.get("threshold", self.DEFAULT_THRESHOLD)

        # 计算变化幅度
        change_pct = abs(current - baseline) / baseline if baseline > 0 else 0.0

        is_alert = change_pct > threshold
        risk_level = "INFO"
        if change_pct > threshold * 2:
            risk_level = "CRITICAL"
        elif change_pct > threshold:
            risk_level = "WARNING"

        return {
            "is_alert": is_alert,
            "change_pct": round(change_pct, 4),
            "risk_level": risk_level,
            "current_value": current,
            "baseline": baseline,
        }

    async def act(self, ctx: AgentContext, decision: dict) -> AgentReport:
        """根据决策生成告警报告。"""
        is_alert = decision.get("is_alert", False)
        risk_level = decision.get("risk_level", "INFO")
        change_pct = decision.get("change_pct", 0.0)

        # 记录到 memory
        if self.memory:
            target = ctx.payload.get("target", "unknown")
            await self.memory.set(
                f"baseline:{target}",
                {"value": decision.get("current_value", 0.0)},
            )

        return AgentReport(
            agent_id=self.agent_id,
            name=self.name,
            verdict=Verdict.RISK if is_alert else Verdict.SAFE,
            confidence=0.95,
            evidence=[
                f"风险等级: {risk_level}",
                f"变化幅度: {change_pct:.2%}",
            ],
            recommended_action=Action.ALERT if is_alert else Action.WATCH,
            metrics={
                "change_pct": change_pct,
                "risk_level": risk_level,
            },
        )
