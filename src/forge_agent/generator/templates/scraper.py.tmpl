"""数据抓取类 Agent 模板 — 从网页/API 获取结构化数据。

支持：
- HTTP/HTTPS 请求（httpx）
- HTML 解析（BeautifulSoup）
- JSON API 解析
- RSS/Atom 订阅源
- 反爬策略（User-Agent 轮换、请求延迟）
- 超时重试
- 数据清洗与标准化
- 时序数据存储（SQLite）
- 定时调度（Cron/固定间隔）
"""

from __future__ import annotations

import logging
from typing import ClassVar

from forge_agent.core.base import BaseAgent
from forge_agent.core.context import AgentContext
from forge_agent.core.contracts import AgentReport
from forge_agent.core.enums import Verdict
from forge_agent.scraper import (
    FieldDef,
    ScraperConfig,
    ScraperEngine,
    SourceType,
)
from forge_agent.storage import ForgeStore

log = logging.getLogger(__name__)


class ScraperAgent(BaseAgent):
    """数据抓取 Agent — 从指定 URL/API 获取结构化信息并存储。

    支持 HTML 页面、JSON API、RSS 三种数据源。
    内置反爬策略、重试机制、时序存储、定时调度。
    """

    agent_id: ClassVar[str] = "domain.scraper_name"
    name: ClassVar[str] = "Scraper Agent"
    domain: ClassVar[str] = "generic"
    version: ClassVar[str] = "0.1.0"

    # ---- Scraper 配置 ----
    # 子类应该覆盖这个方法来定义具体的抓取配置
    def get_scraper_config(self, ctx: AgentContext) -> ScraperConfig:
        """返回 ScraperConfig 配置。

        可以从 ctx.payload 动态获取参数，也可以使用固定配置。
        """
        return ScraperConfig(
            agent_id=self.agent_id,
            name=self.name,
            source_type=SourceType.HTML,
            urls=ctx.payload.get("urls", []),
            fields=[
                FieldDef(name="title", selector="h1", type="str"),
                FieldDef(name="content", selector=".content", type="str"),
            ],
            interval_seconds=3600,  # 每小时
        )

    async def observe(self, ctx: AgentContext) -> dict:
        """执行抓取并存储数据。

        从 ctx.payload 获取配置参数，执行抓取，将结果存入 ForgeStore。
        """
        config = self.get_scraper_config(ctx)
        store = ForgeStore()
        engine = ScraperEngine(config, store)

        # 执行抓取
        records = await engine.run()

        # 获取最新数据用于决策
        latest = store.get_latest(self.agent_id, limit=10)

        return {
            "records_stored": len(records),
            "total_records": len(latest),
            "latest_data": [r.to_dict() for r in latest],
            "config": config.to_dict(),
            "fetched_at": ctx.now_iso(),
        }

    async def decide(self, ctx: AgentContext, observation: dict) -> dict:
        """评估抓取结果的质量和完整性。"""
        records_stored = observation.get("records_stored", 0)
        total_records = observation.get("total_records", 0)
        latest_data = observation.get("latest_data", [])

        if records_stored == 0 and total_records == 0:
            return {
                "action": "fail",
                "reason": "没有抓取到任何数据",
                "quality": "empty",
            }

        # 检查数据完整性
        quality = "good" if records_stored > 0 else "partial"

        return {
            "quality": quality,
            "action": "proceed",
            "records_stored": records_stored,
            "total_records": total_records,
            "latest_sample": latest_data[0] if latest_data else None,
        }

    async def act(self, ctx: AgentContext, decision: dict) -> AgentReport:
        """将抓取结果封装为 AgentReport。"""
        quality = decision.get("quality", "unknown")
        action = decision.get("action", "proceed")

        verdict_map = {
            "good": Verdict.LEAN_POSITIVE,
            "partial": Verdict.LEAN_NEUTRAL,
            "empty": Verdict.LEAN_NEGATIVE,
        }
        confidence_map = {"good": 0.9, "partial": 0.6, "empty": 0.2}

        evidence = [
            f"数据质量: {quality}",
            f"本次存储: {decision.get('records_stored', 0)} 条",
            f"历史记录: {decision.get('total_records', 0)} 条",
        ]

        # 添加最新数据摘要
        latest_sample = decision.get("latest_sample")
        if latest_sample and "data" in latest_sample:
            sample_data = latest_sample["data"]
            if isinstance(sample_data, dict):
                # 显示前 3 个字段
                for i, (key, value) in enumerate(sample_data.items()):
                    if i >= 3:
                        break
                    evidence.append(f"{key}: {value}")

        return AgentReport(
            agent_id=self.agent_id,
            name=self.name,
            verdict=verdict_map.get(quality, Verdict.LEAN_NEUTRAL),
            confidence=confidence_map.get(quality, 0.5),
            evidence=evidence,
            recommended_action=action,
            raw={"decision": decision},
        )
