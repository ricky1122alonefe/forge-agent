"""通用类 Agent 模板 — 灵活的通用 Agent。"""

from __future__ import annotations

from typing import ClassVar

from forge_agent.core.base import BaseAgent
from forge_agent.core.context import AgentContext
from forge_agent.core.contracts import AgentReport
from forge_agent.core.enums import Action, Verdict


class GeneralAgent(BaseAgent):
    """通用 Agent — 处理各类自定义任务。"""

    agent_id: ClassVar[str] = "domain.general_name"
    name: ClassVar[str] = "General Agent"
    domain: ClassVar[str] = "generic"
    version: ClassVar[str] = "0.1.0"

    async def observe(self, ctx: AgentContext) -> dict:
        """收集任务上下文。

        通用 Agent 的 observe 通常：
        - 从 ctx.payload 获取任务参数
        - 可能调用 self.searcher 获取外部信息
        """
        task = ctx.payload.get("task", "")
        params = ctx.payload.get("params", {})

        return {
            "task": task,
            "params": params,
            "scope_id": ctx.scope_id,
        }

    async def decide(self, ctx: AgentContext, observation: dict) -> dict:
        """根据观察结果做出决策。"""
        task = observation.get("task", "")

        # 通用决策逻辑
        return {
            "action": "execute",
            "task": task,
            "confidence": 0.8,
        }

    async def act(self, ctx: AgentContext, decision: dict) -> AgentReport:
        """执行动作并返回报告。"""
        action = decision.get("action", "execute")
        confidence = decision.get("confidence", 0.5)
        recommended_action = Action.EXECUTE if action == "execute" else Action.WATCH

        return AgentReport(
            agent_id=self.agent_id,
            name=self.name,
            verdict=Verdict.SAFE if confidence > 0.7 else Verdict.NEUTRAL,
            confidence=confidence,
            evidence=[f"执行动作: {action}"],
            recommended_action=recommended_action,
        )
